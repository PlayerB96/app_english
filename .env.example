# =============================================================================
# Variables compartidas (mismo valor en los 10 servidores)
# =============================================================================

APP_NAME="Caja Rápida"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlsrv
DB_PORT=1433
DB_DATABASE=DBINFOSAP_ALM
DB_USERNAME=infosap_user
DB_PASSWORD=
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=true

# Infra Laravel (sin tablas en SQL Server legacy)
SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Variables por servidor (distintas en cada uno de los 10 nodos)
# =============================================================================
#
# DB_HOST  → IP del SQL Server accesible desde ESE servidor local.
# APP_URL  → URL con la IP/host donde los móviles acceden a ESTE servidor.
#
# Ver plantillas en deploy/env/servidor-XX.env.example

APP_URL=http://192.168.0.10:8000
DB_HOST=172.16.0.131
