APP_NAME="Dev English"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=app_english
DB_USERNAME=app_english
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=43200
AUTH_REMEMBER_LIFETIME=43200

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Integración IA (generación y evaluación de preguntas)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

TOKENS_INITIAL_BALANCE=100
TOKENS_SKIP_LOCKOUT_COST=10
TOKENS_MAX_TIER_RESETS=2
TOKENS_TIER_RESET_COST=30
TOKENS_SUBLEVEL_COMPLETE_REWARD=10
TOKENS_WORLD_UNLOCK_COST=300

# Código público (3 caracteres) que canjea el código interno LN1 (+500 poder)
POWER_REDEEM_LN1_PUBLIC=LN1

VITE_APP_NAME="${APP_NAME}"

# Datos legales del proveedor (footer, libro de reclamaciones, comprobantes)
LEGAL_BUSINESS_NAME="${APP_NAME}"
LEGAL_RUC=00000000000
LEGAL_ADDRESS="Lima, Perú"
LEGAL_EMAIL=contacto@example.com
LEGAL_PHONE=
LEGAL_COMPLAINT_RESPONSE_DAYS=15
